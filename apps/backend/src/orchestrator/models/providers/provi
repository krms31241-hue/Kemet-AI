export type ProviderCapability =
  | "chat"
  | "completion"
  | "streaming"
  | "tool-calling"
  | "function-calling"
  | "structured-output"
  | "json-mode"
  | "reasoning"
  | "vision"
  | "multimodal"
  | "embeddings"
  | "reranking"
  | "image-generation"
  | "moderation"
  | "audio-input"
  | "audio-output"
  | "speech-to-text"
  | "text-to-speech";

export interface ProviderConfig {
  id: string;

  name: string;

  endpoint?: string;

  apiKey?: string;

  organization?: string;

  defaultModel?: string;

  enabled: boolean;

  priority: number;

  timeout: number;

  maxRetries: number;

  headers?: Record<string, string>;

  metadata?: Record<string, unknown>;
}

export interface ProviderUsage {
  promptTokens: number;

  completionTokens: number;

  totalTokens: number;

  cachedTokens?: number;

  estimatedCost?: number;

  currency?: string;

  latencyMs?: number;

  provider?: string;
}

export interface ContentPartText {
  type: "text";

  text: string;
}

export interface ContentPartImage {
  type: "image";

  imageUrl: string;
}

export interface ContentPartAudio {
  type: "audio";

  audioUrl: string;
}

export type MessageContent =
  | string
  | Array<
      | ContentPartText
      | ContentPartImage
      | ContentPartAudio
    >;

export interface ToolCall {
  id: string;

  name: string;

  arguments: Record<string, unknown>;
}

export interface ChatMessage {
  role:
    | "system"
    | "user"
    | "assistant"
    | "tool";

  content: MessageContent;

  name?: string;

  toolCalls?: ToolCall[];

  toolCallId?: string;

  metadata?: Record<string, unknown>;
}

export interface ChatRequest {
  model: string;

  messages: ChatMessage[];

  temperature?: number;

  topP?: number;

  maxTokens?: number;

  stop?: string[];

  stream?: boolean;

  tools?: unknown[];

  toolChoice?: unknown;

  responseFormat?: unknown;

  metadata?: Record<string, unknown>;
}

export interface ChatResponse {
  id: string;

  model: string;

  message: ChatMessage;

  usage?: ProviderUsage;

  finishReason?: string;

  provider?: string;

  createdAt?: Date;

  raw?: unknown;
}
