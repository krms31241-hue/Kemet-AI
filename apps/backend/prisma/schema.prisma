generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  username     String    @unique
  passwordHash String

  firstName    String?
  lastName     String?
  avatarUrl    String?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  projects     Project[]
}

model Project {
  id          String    @id @default(cuid())

  name        String
  description String?

  ownerId     String
  owner       User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  agents      Agent[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Agent {
  id          String    @id @default(cuid())

  name        String
  description String?

  model       String

  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
